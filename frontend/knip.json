{
	"$schema": "https://unpkg.com/knip/dist/schema.json",
	"ignore": [
		".next/**",
		".turbo/**",
		"dist/**",
		"build/**",
		"coverage/**",
		"playwright-report/**",
		"test-results/**",
		".storybook/**",
		"testing/**",
		"e2e/**",
		"**/*.spec.ts",
		"**/*.spec.tsx",
		"**/*.stories.tsx",
		"playwright.config.ts",
		"vitest.setup.ts",
		"knip.config.ts",
		"postcss.config.mjs",
		"next-env.d.ts",
		"next.config.*",
		"eslint.config.*",
		"vitest.config.*",
		"tsconfig*.json"
	],
	"ignoreBinaries": [
		"biome",
		"vitest",
		"playwright",
		"storybook",
		"eslint",
		"knip",
		"only-allow",
		"tsx",
		"tsc",
		"cross-env"
	],
	"ignoreDependencies": ["@grantflow/editor", "tw-animate-css"],
	"ignoreExportsUsedInFile": true
}
