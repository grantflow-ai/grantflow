	"scripts": {
		"biome": "biome",
		"build": "cross-env NODE_NO_WARNINGS=1 next build",
		"build-storybook": "cross-env storybook build",
		"check": "biome check --write . && eslint ",
		"dev": "cross-env NODE_NO_WARNINGS=1 next dev --turbopack",
		"eslint": "eslint",
		"format": "biome format --write .",
		"knip": "knip",
		"knip:fix": "knip --fix",
		"knip:production": "knip --production",
		"lint": "biome lint --write . && eslint . --fix",
		"playwright": "./node_modules/.bin/playwright",
		"preinstall": "npx only-allow pnpm",
		"reset-shadcn": "tsx scripts/reset-shadcn.ts",
		"start": "cross-env NODE_NO_WARNINGS=1 next start",
		"storybook": "cross-env storybook dev -p 6006",
		"test": "cross-env NODE_NO_WARNINGS=1 vitest run",
		"test:coverage": "cross-env NODE_NO_WARNINGS=1 pnpm run test --coverage",
		"test:e2e": "cross-env NODE_NO_WARNINGS=1 ./node_modules/.bin/playwright test",
		"test:e2e:headed": "cross-env NODE_NO_WARNINGS=1 ./node_modules/.bin/playwright test --headed",
		"test:e2e:mock": "cross-env NODE_NO_WARNINGS=1 ./node_modules/.bin/playwright test --config=playwright.mock.config.ts",
		"test:e2e:ui": "cross-env NODE_NO_WARNINGS=1 ./node_modules/.bin/playwright test --ui",
		"test:watch": "cross-env NODE_NO_WARNINGS=1 vitest watch --coverage",
		"typecheck": "tsc --noEmit",
		"ui": "pnpm dlx shadcn@latest"
	},
