# Frontend Environment Variables
# Copy this file to .env and update with your actual values

# Frontend Public Configuration
# These variables are exposed to the browser
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
NEXT_PUBLIC_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=YOUR_MEASUREMENT_ID
NEXT_PUBLIC_FIREBASE_MESSAGE_SENDER_ID=YOUR_MESSAGE_SENDER_ID
NEXT_PUBLIC_FIREBASE_MICROSOFT_TENANT_ID=YOUR_MICROSOFT_TENANT_ID
NEXT_PUBLIC_FIREBASE_PROJECT_ID=grantflow
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.firebasestorage.app
NEXT_PUBLIC_BACKEND_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_GCS_EMULATOR_URL=http://localhost:4443
NEXT_PUBLIC_DEBUG=true
NEXT_PUBLIC_MOCK_API=true
NEXT_PUBLIC_MOCK_AUTH=true
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY

# Server-side Frontend Configuration
# These variables are only available server-side (e.g., for email sending)
RESEND_API_KEY=YOUR_RESEND_API_KEY