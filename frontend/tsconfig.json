{
	"extends": "../tsconfig.json",
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"],
			"::testing/*": ["testing/*"]
		},
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"jsx": "preserve",
		"moduleResolution": "bundler",
		"types": ["vitest/globals", "@testing-library/jest-dom"],
		"plugins": [
			{
				"name": "next"
			}
		]
	},
	"exclude": ["node_modules"],
	"include": [
		"**/*.d.ts",
		"**/*.mjs",
		"**/*.ts",
		"**/*.tsx",
		"**/*.mts",
		"*.cjs",
		"*.d.ts",
		"*.js",
		"*.mjs",
		"*.mts",
		"*.ts",
		".next/types/**/*.ts",
		".storybook/*.ts",
		".storybook/*.tsx"
	]
}
