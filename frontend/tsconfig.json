{
	"compilerOptions": {
		"baseUrl": ".",
		"jsx": "preserve",
		"paths": {
			"::storybook/*": [".storybook/*"],
			"::testing/*": ["testing/*"],
			"@/*": ["src/*"]
		},
		"plugins": [
			{
				"name": "next"
			}
		]
	},
	"exclude": ["node_modules"],
	"extends": "../tsconfig.json",
	"include": [
		"**/*.d.ts",
		"**/*.mjs",
		"**/*.ts",
		"**/*.tsx",
		"**/*.mts",
		"*.cjs",
		"*.d.ts",
		"*.js",
		"*.mjs",
		"*.mts",
		"*.ts",
		"next-env.d.ts",
		".next/types/**/*.ts",
		".storybook/**/*.ts",
		".storybook/**/*.tsx"
	]
}
