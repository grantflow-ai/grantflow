erDiagram
    %% Core Organization Tables
    Organization {
        UUID id PK
        String name
        Text description
        Text logo_url
        String contact_email
        String contact_person_name
        String institutional_affiliation
        JSON settings
        DateTime created_at
        DateTime updated_at
        DateTime deleted_at
    }

    OrganizationUser {
        String firebase_uid PK
        UUID organization_id PK,FK
        UserRoleEnum role
        Boolean has_all_projects_access
        DateTime joined_at
        DateTime created_at
        DateTime updated_at
        DateTime deleted_at
    }

    OrganizationAuditLog {
        UUID id PK
        UUID organization_id FK
        String user_firebase_uid
        String action
        String target_user_firebase_uid
        JSON details
        String ip_address
        DateTime created_at
        DateTime updated_at
        DateTime deleted_at
    }

    OrganizationInvitation {
        UUID id PK
        UUID organization_id FK
        String email
        UserRoleEnum role
        DateTime invitation_sent_at
        DateTime accepted_at
        DateTime created_at
        DateTime updated_at
        DateTime deleted_at
    }

    %% Project Tables
    Project {
        UUID id PK
        UUID organization_id FK
        String name
        Text description
        Text logo_url
        DateTime created_at
        DateTime updated_at
        DateTime deleted_at
    }

    ProjectAccess {
        String firebase_uid PK,FK
        UUID organization_id PK,FK
        UUID project_id PK,FK
        DateTime granted_at
        DateTime created_at
        DateTime updated_at
        DateTime deleted_at
    }

    %% Grant Tables
    GrantApplication {
        UUID id PK
        DateTime completed_at
        JSON form_inputs
        JSON research_objectives
        ApplicationStatusEnum status
        Text text
        String title
        Text description
        UUID project_id FK
        UUID rag_job_id FK
        UUID parent_id FK
        DateTime created_at
        DateTime updated_at
        DateTime deleted_at
    }

    GrantTemplate {
        UUID id PK
        JSON grant_sections
        UUID grant_application_id FK
        UUID granting_institution_id FK
        UUID rag_job_id FK
        Date submission_date
        DateTime created_at
        DateTime updated_at
        DateTime deleted_at
    }

    GrantingInstitution {
        UUID id PK
        String full_name
        String abbreviation
        DateTime created_at
        DateTime updated_at
        DateTime deleted_at
    }

    %% RAG Tables
    RagSource {
        UUID id PK
        SourceIndexingStatusEnum indexing_status
        Text text_content
        String source_type
        DateTime created_at
        DateTime updated_at
        DateTime deleted_at
    }

    RagFile {
        UUID id PK,FK
        String bucket_name
        String object_path
        String filename
        String mime_type
        BigInteger size
    }

    RagUrl {
        UUID id PK,FK
        Text url
        String title
        Text description
    }

    TextVector {
        UUID id PK
        JSON chunk
        Vector embedding
        UUID rag_source_id FK
        DateTime created_at
        DateTime updated_at
        DateTime deleted_at
    }

    %% RAG Generation Tables
    RagGenerationJob {
        UUID id PK
        RagGenerationStatusEnum status
        BigInteger current_stage
        BigInteger total_stages
        BigInteger retry_count
        Text error_message
        JSON error_details
        JSON checkpoint_data
        DateTime started_at
        DateTime completed_at
        DateTime failed_at
        String job_type
        DateTime created_at
        DateTime updated_at
        DateTime deleted_at
    }

    GrantTemplateGenerationJob {
        UUID id PK,FK
        UUID grant_template_id FK
        JSON extracted_sections
        JSON extracted_metadata
    }

    GrantApplicationGenerationJob {
        UUID id PK,FK
        UUID grant_application_id FK
        JSON generated_sections
        JSON validation_results
    }

    GenerationNotification {
        UUID id PK
        UUID rag_job_id FK
        String event
        Text message
        JSON data
        BigInteger current_pipeline_stage
        BigInteger total_pipeline_stages
        String notification_type
        DateTime created_at
        DateTime updated_at
        DateTime deleted_at
    }

    %% Join Tables
    GrantApplicationSource {
        UUID grant_application_id PK,FK
        UUID rag_source_id PK,FK
        DateTime created_at
        DateTime updated_at
        DateTime deleted_at
    }

    GrantTemplateSource {
        UUID rag_source_id PK,FK
        UUID grant_template_id PK,FK
        DateTime created_at
        DateTime updated_at
        DateTime deleted_at
    }

    GrantingInstitutionSource {
        UUID rag_source_id PK,FK
        UUID granting_institution_id PK,FK
        DateTime created_at
        DateTime updated_at
        DateTime deleted_at
    }

    %% Notification Table
    Notification {
        UUID id PK
        String firebase_uid
        UUID organization_id FK
        UUID project_id FK
        NotificationTypeEnum type
        String title
        Text message
        String project_name
        Boolean read
        Boolean dismissed
        DateTime expires_at
        JSON extra_data
        DateTime created_at
        DateTime updated_at
        DateTime deleted_at
    }

    %% Relationships
    Organization ||--o{ OrganizationUser : "has"
    Organization ||--o{ Project : "has"
    Organization ||--o{ OrganizationAuditLog : "logs"
    Organization ||--o{ OrganizationInvitation : "invites"
    Organization ||--o{ Notification : "generates"

    Project ||--o{ GrantApplication : "contains"
    Project ||--o{ ProjectAccess : "grants access"
    Project ||--o{ Notification : "generates"

    OrganizationUser ||--o{ ProjectAccess : "has access"

    GrantApplication ||--o| GrantTemplate : "has"
    GrantApplication ||--o{ GrantApplicationSource : "uses"
    GrantApplication ||--o| GrantApplicationGenerationJob : "generates with"
    GrantApplication ||--o| GrantApplication : "parent-child"

    GrantTemplate ||--o{ GrantTemplateSource : "uses"
    GrantTemplate }o--o| GrantingInstitution : "belongs to"
    GrantTemplate ||--o| GrantTemplateGenerationJob : "generates with"

    GrantingInstitution ||--o{ GrantingInstitutionSource : "has sources"

    RagSource ||--o{ TextVector : "has vectors"
    RagSource ||--o{ GrantApplicationSource : "used by"
    RagSource ||--o{ GrantTemplateSource : "used by"
    RagSource ||--o{ GrantingInstitutionSource : "used by"

    RagFile ||--|| RagSource : "is a"
    RagUrl ||--|| RagSource : "is a"

    RagGenerationJob ||--o{ GenerationNotification : "produces"
    
    GrantTemplateGenerationJob ||--|| RagGenerationJob : "is a"
    GrantApplicationGenerationJob ||--|| RagGenerationJob : "is a"

    ProjectAccess }o--|| Project : "accesses"