{
	"name": "nextjs-template",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"build": "next build",
		"db:create-migration": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:seed": "pnpm dlx tsx --env-file=.env scripts/seed-db.ts",
		"dev": "NODE_NO_WARNINGS=1 next dev --turbopack",
		"format": "prettier --write .",
		"lint:check": "eslint .",
		"lint:fix": "eslint --fix '**/*.{js,cjs,mjs,jsx,mjsx,cjsx,ts,tsx,mts,cjs,mtsx,ctsx}'",
		"preinstall": "npx only-allow pnpm",
		"postinstall": "rm -rf node_modules/pg-cloudflare",
		"prepare": "husky",
		"start": "NODE_NO_WARNINGS=1 next start",
		"test": "NODE_NO_WARNINGS=1 vitest",
		"test:coverage": "NODE_NO_WARNINGS=1 pnpm run test --coverage",
		"test:watch": "NODE_NO_WARNINGS=1 pnpm run test --watch --coverage",
		"ui": "pnpm dlx shadcn@latest"
	},
	"lint-staged": {
		"*.{js,cjs,mjs,jsx,mjsx,cjsx,ts,tsx,mts,cjs,mtsx,ctsx,json,html,css,json,yaml,yml}": "prettier --write",
		"*.{js,cjs,mjs,jsx,mjsx,cjsx,ts,tsx,mts,cjs,mtsx,ctsx}": [
			"eslint --fix --no-warn-ignored"
		]
	},
	"dependencies": {
		"@auth/drizzle-adapter": "^1.7.4",
		"@azure/storage-blob": "^12.25.0",
		"@hookform/resolvers": "^3.9.1",
		"@icons-pack/react-simple-icons": "^10.1.0",
		"@radix-ui/react-accordion": "^1.2.1",
		"@radix-ui/react-avatar": "^1.1.1",
		"@radix-ui/react-checkbox": "^1.1.2",
		"@radix-ui/react-dialog": "^1.1.2",
		"@radix-ui/react-icons": "^1.3.2",
		"@radix-ui/react-label": "^2.1.0",
		"@radix-ui/react-popover": "^1.1.2",
		"@radix-ui/react-progress": "^1.1.0",
		"@radix-ui/react-scroll-area": "^1.2.1",
		"@radix-ui/react-select": "^2.1.2",
		"@radix-ui/react-separator": "^1.1.0",
		"@radix-ui/react-slot": "^1.1.0",
		"@radix-ui/react-tooltip": "^1.1.4",
		"@t3-oss/env-nextjs": "^0.11.1",
		"@tool-belt/type-predicates": "^1.3.0",
		"class-variance-authority": "^0.7.0",
		"clsx": "^2.1.1",
		"cmdk": "1.0.4",
		"drizzle-orm": "^0.36.3",
		"lucide-react": "^0.460.0",
		"next": "15.0.3",
		"next-auth": "5.0.0-beta.25",
		"next-themes": "^0.4.3",
		"pg": "^8.13.1",
		"react": "19.0.0-rc-69d4b800-20241021",
		"react-dom": "19.0.0-rc-69d4b800-20241021",
		"react-dropzone": "^14.3.5",
		"react-hook-form": "^7.53.2",
		"react-markdown": "^9.0.1",
		"sonner": "^1.7.0",
		"validator": "^13.12.0",
		"zod": "^3.23.8",
		"zustand": "^5.0.1"
	},
	"devDependencies": {
		"@commitlint/config-conventional": "^19.5.0",
		"@faker-js/faker": "^9.2.0",
		"@tailwindcss/forms": "^0.5.9",
		"@testing-library/dom": "^10.4.0",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.0.1",
		"@testing-library/user-event": "^14.5.2",
		"@trumpet/eslint-config-next": "^1.1.2",
		"@types/node": "^22.9.0",
		"@types/pg": "^8.11.10",
		"@types/react": "npm:types-react@19.0.0-rc.1",
		"@types/react-dom": "npm:types-react-dom@19.0.0-rc.1",
		"@types/validator": "^13.12.2",
		"@vitejs/plugin-react": "^4.3.3",
		"@vitest/coverage-v8": "^2.1.5",
		"autoprefixer": "^10.4.20",
		"drizzle-kit": "^0.28.1",
		"eslint": "^9.15.0",
		"eslint-config-prettier": "^9.1.0",
		"husky": "^9.1.6",
		"interface-forge": "^2.0.1",
		"jiti": "2.4.0",
		"jsdom": "^25.0.1",
		"lint-staged": "^15.2.10",
		"postcss": "^8.4.49",
		"prettier": "^3.3.3",
		"tailwind-merge": "^2.5.4",
		"tailwindcss": "^3.4.15",
		"tailwindcss-animate": "^1.0.7",
		"typescript": "^5.6.3",
		"typescript-eslint": "^8.14.0",
		"vite-tsconfig-paths": "^5.1.2",
		"vitest": "^2.1.5"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"pnpm": {
		"peerDependencyRules": {
			"allowAny": [
				"eslint",
				"react",
				"react-dom",
				"@types/react",
				"@types/react-dom"
			]
		},
		"overrides": {
			"@types/react": "npm:types-react@19.0.0-rc.1",
			"@types/react-dom": "npm:types-react-dom@19.0.0-rc.1"
		}
	}
}
