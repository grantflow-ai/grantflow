{
	"name": "grantflow-frontend",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"build": "NODE_NO_WARNINGS=1 next build",
		"dev": "NODE_NO_WARNINGS=1 next dev --turbopack",
		"format": "prettier --write .",
		"check": "eslint .",
		"lint": "eslint --fix '**/*.{js,cjs,mjs,jsx,mjsx,cjsx,ts,tsx,mts,cjs,mtsx,ctsx}'",
		"preinstall": "npx only-allow pnpm",
		"prepare": "husky",
		"start": "NODE_NO_WARNINGS=1 next start",
		"test": "NODE_NO_WARNINGS=1 vitest",
		"test:coverage": "NODE_NO_WARNINGS=1 pnpm run test --coverage",
		"test:watch": "NODE_NO_WARNINGS=1 pnpm run test --watch --coverage",
		"ui": "pnpm dlx shadcn@latest"
	},
	"lint-staged": {
		"*.{js,cjs,mjs,jsx,mjsx,cjsx,ts,tsx,mts,cjs,mtsx,ctsx,json,html,css,json,yaml,yml}": "prettier --write",
		"*.{js,cjs,mjs,jsx,mjsx,cjsx,ts,tsx,mts,cjs,mtsx,ctsx}": [
			"eslint --fix --no-warn-ignored"
		]
	},
	"dependencies": {
		"@hookform/resolvers": "^3.10.0",
		"@icons-pack/react-simple-icons": "^11.1.0",
		"@radix-ui/react-accordion": "^1.2.2",
		"@radix-ui/react-alert-dialog": "^1.1.4",
		"@radix-ui/react-checkbox": "^1.1.3",
		"@radix-ui/react-collapsible": "^1.1.2",
		"@radix-ui/react-dialog": "^1.1.4",
		"@radix-ui/react-icons": "^1.3.2",
		"@radix-ui/react-label": "^2.1.1",
		"@radix-ui/react-popover": "^1.1.4",
		"@radix-ui/react-scroll-area": "^1.2.2",
		"@radix-ui/react-select": "^2.1.4",
		"@radix-ui/react-separator": "^1.1.1",
		"@radix-ui/react-slot": "^1.1.1",
		"@radix-ui/react-tabs": "^1.1.2",
		"@radix-ui/react-tooltip": "^1.1.6",
		"@t3-oss/env-nextjs": "^0.11.1",
		"@vercel/analytics": "^1.4.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "1.0.4",
		"firebase": "^11.2.0",
		"ky": "^1.7.4",
		"lucide-react": "^0.473.0",
		"next": "15.1.5",
		"next-themes": "^0.4.4",
		"react": "19.0.0",
		"react-dom": "19.0.0",
		"react-dropzone": "^14.3.5",
		"react-hook-form": "^7.54.2",
		"sonner": "^1.7.2",
		"validator": "^13.12.0",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@commitlint/config-conventional": "^19.6.0",
		"@faker-js/faker": "^9.4.0",
		"@testing-library/dom": "^10.4.0",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.2.0",
		"@testing-library/user-event": "^14.6.0",
		"@trumpet/eslint-config-next": "^1.6.3",
		"@types/node": "^22.10.7",
		"@types/prismjs": "^1.26.5",
		"@types/react": "19.0.7",
		"@types/react-dom": "19.0.3",
		"@types/validator": "^13.12.2",
		"@vitejs/plugin-react": "^4.3.4",
		"@vitest/coverage-v8": "^3.0.2",
		"autoprefixer": "^10.4.20",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.0.1",
		"husky": "^9.1.7",
		"interface-forge": "^2.0.1",
		"jsdom": "^26.0.0",
		"lint-staged": "^15.4.1",
		"postcss": "^8.5.1",
		"prettier": "^3.4.2",
		"tailwind-merge": "^2.6.0",
		"tailwindcss": "^3.4.17",
		"tailwindcss-animate": "^1.0.7",
		"typescript": "^5.7.3",
		"typescript-eslint": "^8.20.0",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^3.0.2"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"pnpm": {
		"peerDependencyRules": {
			"allowAny": [
				"eslint",
				"react",
				"react-dom"
			]
		}
	},
	"packageManager": "pnpm@9.15.1+sha512.1acb565e6193efbebda772702950469150cf12bcc764262e7587e71d19dc98a423dff9536e57ea44c49bdf790ff694e83c27be5faa23d67e0c033b583be4bfcf"
}
