{
	"name": "nextjs-template",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"build": "next build",
		"db:create-migration": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:seed": "pnpm dlx tsx --env-file=.env scripts/seed-db.ts",
		"dev": "next dev",
		"format": "prettier --write .",
		"lint:check": "eslint .",
		"lint:fix": "eslint --fix '**/*.{js,cjs,mjs,jsx,mjsx,cjsx,ts,tsx,mts,cjs,mtsx,ctsx}'",
		"preinstall": "npx only-allow pnpm",
		"prepare": "husky",
		"start": "next start",
		"test": "NODE_NO_WARNINGS=1 vitest",
		"test:coverage": "pnpm run test --coverage",
		"test:watch": "pnpm run test --watch --coverage",
		"ui": "pnpm dlx shadcn@latest"
	},
	"lint-staged": {
		"*.{js,cjs,mjs,jsx,mjsx,cjsx,ts,tsx,mts,cjs,mtsx,ctsx,json,html,css,json,yaml,yml}": "prettier --write",
		"*.{js,cjs,mjs,jsx,mjsx,cjsx,ts,tsx,mts,cjs,mtsx,ctsx}": [
			"eslint --fix --no-warn-ignored"
		]
	},
	"dependencies": {
		"@auth/drizzle-adapter": "^1.7.0",
		"@azure/storage-blob": "^12.25.0",
		"@formatjs/intl-localematcher": "^0.5.5",
		"@hookform/resolvers": "^3.9.0",
		"@icons-pack/react-simple-icons": "^10.0.0",
		"@radix-ui/react-accordion": "^1.2.1",
		"@radix-ui/react-avatar": "^1.1.1",
		"@radix-ui/react-collapsible": "^1.1.1",
		"@radix-ui/react-dialog": "^1.1.2",
		"@radix-ui/react-icons": "^1.3.0",
		"@radix-ui/react-label": "^2.1.0",
		"@radix-ui/react-popover": "^1.1.2",
		"@radix-ui/react-progress": "^1.1.0",
		"@radix-ui/react-scroll-area": "^1.2.0",
		"@radix-ui/react-select": "^2.1.2",
		"@radix-ui/react-separator": "^1.1.0",
		"@radix-ui/react-slot": "^1.1.0",
		"@radix-ui/react-switch": "^1.1.1",
		"@radix-ui/react-toast": "^1.2.2",
		"@radix-ui/react-tooltip": "^1.1.3",
		"@t3-oss/env-nextjs": "^0.11.1",
		"@tool-belt/type-predicates": "^1.3.0",
		"axios": "^1.7.7",
		"class-variance-authority": "^0.7.0",
		"clsx": "^2.1.1",
		"cmdk": "1.0.0",
		"date-fns": "^4.1.0",
		"drizzle-orm": "^0.34.1",
		"inflection": "^3.0.0",
		"lucide-react": "^0.452.0",
		"nanoid": "^5.0.7",
		"negotiator": "^0.6.3",
		"next": "14.2.15",
		"next-auth": "5.0.0-beta.22",
		"next-themes": "^0.3.0",
		"postgres": "^3.4.4",
		"prettier": "^3.3.3",
		"react": "^18.3.1",
		"react-day-picker": "8.10.1",
		"react-dom": "^18.3.1",
		"react-hook-form": "^7.53.0",
		"remeda": "^2.15.0",
		"sonner": "^1.5.0",
		"validator": "^13.12.0",
		"zod": "^3.23.8",
		"zustand": "5.0.0-rc.2"
	},
	"devDependencies": {
		"@commitlint/config-conventional": "^19.5.0",
		"@faker-js/faker": "^9.0.3",
		"@tailwindcss/forms": "^0.5.9",
		"@testing-library/dom": "^10.4.0",
		"@testing-library/jest-dom": "^6.5.0",
		"@testing-library/react": "^16.0.1",
		"@testing-library/user-event": "^14.5.2",
		"@trumpet/eslint-config-next": "^1.1.1",
		"@types/negotiator": "^0.6.3",
		"@types/node": "^22.7.5",
		"@types/react": "^18.3.11",
		"@types/react-dom": "^18.3.1",
		"@types/validator": "^13.12.2",
		"@vitejs/plugin-react": "^4.3.2",
		"@vitest/coverage-v8": "^2.1.2",
		"autoprefixer": "^10.4.20",
		"drizzle-kit": "^0.25.0",
		"eslint": "^9.12.0",
		"eslint-config-prettier": "^9.1.0",
		"husky": "^9.1.6",
		"interface-forge": "^2.0.1",
		"jiti": "2.3.3",
		"jsdom": "^25.0.1",
		"lint-staged": "^15.2.10",
		"postcss": "^8.4.47",
		"tailwind-merge": "^2.5.3",
		"tailwindcss": "^3.4.13",
		"tailwindcss-animate": "^1.0.7",
		"typescript": "^5.6.3",
		"typescript-eslint": "^8.8.1",
		"vite-tsconfig-paths": "^5.0.1",
		"vitest": "^2.1.2"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"pnpm": {
		"peerDependencyRules": {
			"allowAny": [
				"eslint",
				"react",
				"react-dom"
			]
		}
	}
}
