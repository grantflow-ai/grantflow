# Backend and Services Environment Variables
# Copy this file to .env and update with your actual values

# Figma API Token
FIGMA_TOKEN=YOUR_FIGMA_TOKEN

# Database Configuration
DATABASE_CONNECTION_STRING=postgresql+asyncpg://local:local@localhost:5432/local

# Discord webhook for monitoring alerts
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT=grantflow
GOOGLE_CLOUD_REGION=us-central1

# AI/LLM API Keys
GOOGLE_AI_API_KEY=YOUR_GOOGLE_AI_API_KEY_HERE
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# Model Configuration (optional - has fallbacks in code)
GENERATION_MODEL=gemini-2.5-flash
EVALUATION_MODEL=gemini-2.5-flash
REASONING_MODEL=gemini-2.5-flash
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-20250514

# Service Account Credentials (JSON content from service account key files)
LLM_SERVICE_ACCOUNT_CREDENTIALS={"type":"service_account","project_id":"grantflow","private_key_id":"YOUR_PRIVATE_KEY_ID","private_key":"-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----\n","client_email":"llm-api-service-account@grantflow.iam.gserviceaccount.com","client_id":"YOUR_CLIENT_ID","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/llm-api-service-account%40grantflow.iam.gserviceaccount.com","universe_domain":"googleapis.com"}

# Google Cloud Storage Service Account
GCS_SERVICE_ACCOUNT_CREDENTIALS={"type":"service_account","project_id":"grantflow","private_key_id":"YOUR_PRIVATE_KEY_ID","private_key":"-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----\n","client_email":"cloud-storage-admin@grantflow.iam.gserviceaccount.com","client_id":"YOUR_CLIENT_ID","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/cloud-storage-admin%40grantflow.iam.gserviceaccount.com","universe_domain":"googleapis.com"}

# Firebase Backend Service Configuration
FIREBASE_SERVICE_ACCOUNT_CREDENTIALS={"type":"service_account","project_id":"grantflow","private_key_id":"YOUR_PRIVATE_KEY_ID","private_key":"-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----\n","client_email":"backend-service@grantflow.iam.gserviceaccount.com","client_id":"YOUR_CLIENT_ID","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-skwn4%40grantflow.iam.gserviceaccount.com","universe_domain":"googleapis.com"}
JWT_SECRET=YOUR_JWT_SECRET_HERE
ADMIN_ACCESS_CODE=YOUR_ADMIN_ACCESS_CODE

# Stripe Configuration (Backend)
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_SUCCESS_URL=http://localhost:3000/billing/success
STRIPE_CANCEL_URL=http://localhost:3000/billing
STRIPE_PORTAL_RETURN_URL=http://localhost:3000/billing
# STRIPE_WEBHOOK_SECRET=whsec_  # Will be set when you run stripe listen
# STRIPE_PORTAL_CONFIG_ID=  # Optional: Set if you have a specific portal configuration

# Pub/Sub Topics
FRONTEND_NOTIFICATIONS_PUBSUB_TOPIC=frontend-notifications

# Scraper Service Configuration
SCRAPER_GCS_BUCKET_NAME=grantflow-scraper

# Development Settings
DEBUG=True