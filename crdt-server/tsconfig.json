{
	"compilerOptions": {
		"baseUrl": ".",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"incremental": false,
		"module": "ESNext",
		"moduleResolution": "node",
		"outDir": "dist",
		"paths": {
			"@/*": ["src/*"]
		},
		"rootDir": "src",
		"skipLibCheck": true,
		"strict": true,
		"target": "ESNext",
		"types": ["vitest/globals"]
	},
	"exclude": ["node_modules", "dist"],
	"extends": "../tsconfig.json",
	"include": ["src/**/*.ts", "testing/**/*.ts", "drizzle.config.ts", "tsup.config.ts", "vitest.config.ts"]
}
