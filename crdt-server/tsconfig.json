{
	"extends": "../tsconfig.json",
	"compilerOptions": {
		"baseUrl": ".",
		"outDir": "dist",
		"rootDir": "src",
		"module": "ESNext",
		"target": "ESNext",
		"moduleResolution": "node",
		"incremental": false,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"types": ["vitest/globals"],
		"paths": {
			"@/*": ["src/*"]
		}
	},
	"include": ["src/**/*.ts", "tsup.config.ts", "drizzle.config.ts"],
	"exclude": ["node_modules", "dist"]
}
