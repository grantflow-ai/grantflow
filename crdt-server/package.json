{
	"author": "",
	"dependencies": {
		"@hocuspocus/extension-database": "^3.2.2",
		"@hocuspocus/server": "^3.2.2",
		"dotenv": "^17.2.1",
		"drizzle-orm": "^0.44.4",
		"pg": "^8.16.3",
		"pino": "^9.7.0",
		"zod": "^4.0.14"
	},
	"description": "",
	"devDependencies": {
		"@types/pg": "^8.15.5",
		"@typescript-eslint/eslint-plugin": "^8.39.0",
		"@typescript-eslint/parser": "^8.39.0",
		"drizzle-kit": "^0.31.4",
		"eslint": "^9.32.0",
		"nodemon": "^3.1.10",
		"pino-pretty": "^13.1.1",
		"tsup": "^8.5.0",
		"typescript": "^5.9.2"
	},
	"keywords": [],
	"license": "UNLICENSED",
	"main": "dist/index.js",
	"name": "crdt-server",
	"packageManager": "pnpm@10.13.1",
	"scripts": {
		"biome": "biome",
		"build": "tsup src/index.ts --dts --format cjs --out-dir dist",
		"check": "biome check --write . && eslint ",
		"db:introspect": "drizzle-kit introspect && mv drizzle/schema.ts src/db/schema.ts && mv drizzle/relations.ts src/db/relations.ts && pnpm lint",
		"dev": "nodemon --watch src --ext ts --exec \"pnpm run build && node dist/index.js\"",
		"eslint": "eslint",
		"format": "biome format --write .",
		"lint": "biome lint --write . && eslint . --fix",
		"start": "node dist/index.js",
		"test": "vitest run"
	},
	"version": "1.0.0"
}
